---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = '三国志NET',
  description = '原典完全準拠、ブラウザで遊べる三国志ネットゲーム。内政・外交・合戦のすべてが、あの頃のまま蘇る。',
} = Astro.props;

// TwitterカードなどのOGPは絶対URLでないと画像が拾われないため、
// astro.config.mjs の site/base を使って絶対URLを組み立てる。
const ogImageUrl = new URL(`${import.meta.env.BASE_URL}ogp.png`, Astro.site).toString();
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="theme-color" content="#1a120f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f7f4ef" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OGP（Facebook/LINE等）＋ Twitterカード -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="三国志NET" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={pageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <!--
      テーマの適用は必ずレンダリング前・<head>内の同期スクリプトで行う。
      React読み込みを待つと一瞬だけ誤ったテーマが見えてしまう(FOUC)ため、
      GameAppアイランドの外、素のvanilla JSでここだけ即時実行する。
    -->
    <script is:inline>
      (function () {
        var stored = null;
        try { stored = localStorage.getItem('sangoku-theme'); } catch (e) {}
        var theme = stored === 'light' || stored === 'dark'
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
